generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  patients     Patient[]
}

model Patient {
  id                   Int           @id @default(autoincrement())
  userId               String
  name                 String
  phone                String
  clinicName           String?
  clinicColor          String?
  address              String?
  age                  Int?
  occupation           String?
  treatment            String
  treatmentCategory    String?
  bracketType          String?
  caseSheet            String?
  attachments          Json?
  appointmentDate      String
  appointmentTime      String?
  firstAppointment     Boolean       @default(false)
  notes                String?
  plannedNotes         String?
  totalFee             Float?
  totalPaid            Float?
  retainerFee          Float?
  elasticEnabled       Boolean       @default(false)
  elasticType          String?
  tadsNote             String?
  caseStatus           String?
  visits               Json?
  myofunctionalType    String?
  myofunctionalProgram Json?
  clearAlignersPlan    Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  appointments         Appointment[]
  user                 User          @relation(fields: [userId], references: [id])
}

model Appointment {
  id              Int      @id @default(autoincrement())
  patientId       Int
  appointmentDate String
  appointmentTime String?
  status          String   @default("scheduled")
  type            String?
  notes           String?
  reminderSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id])
}
