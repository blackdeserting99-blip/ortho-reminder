{
  "name": "ortho-reminder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "cf:build": "prisma generate && prisma migrate deploy && npx @opennextjs/cloudflare build",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "7.9.0",
    "@prisma/client": "7.9.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.21.0",
    "next": "15.5.21",
    "next-auth": "^4.24.14",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.21",
    "prisma": "7.9.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
}
